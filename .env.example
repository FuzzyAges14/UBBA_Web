# =============================================================================
# UBBA API — copy to `.env` and fill in. Never commit real secrets.
# =============================================================================
# Edit recipient emails / Instagram / Facebook in: src/data/contact.ts
# Optional overrides below win over that file.

API_PORT=3001

# NODE_ENV=production is typically set by your host. In production, empty
# CORS_ORIGINS rejects browser Origins — set it explicitly before go-live.

# Optional: override notify inboxes (comma-separated). Defaults to CONTACT.notifyEmails.
# NOTIFY_EMAILS=info@unitedbba.com,owner@example.com

# Optional: per-form inbox overrides (birthday parties, summer camp, etc.)
# NOTIFY_EMAILS_BIRTHDAY=parties@unitedbba.com
# NOTIFY_EMAILS_SUMMER_CAMP=camp@unitedbba.com
# NOTIFY_EMAILS_PARENTS_NIGHT_OUT=events@unitedbba.com
# NOTIFY_EMAILS_FREE_CLASS=trials@unitedbba.com

# Optional: envelope From address (Resend needs a verified domain address).
# MAIL_FROM_EMAIL=leads@yourdomain.com
# MAIL_FROM_NAME=UBBA Website

# --- Pick ONE mail transport ---

# Option A — Resend (https://resend.com): free tier, simplest for most hosts
# RESEND_API_KEY=re_xxxxxxxx

# Option B — SMTP URL (Gmail, Outlook, SendGrid, Mailgun, etc.)
# SMTP_URL=smtps://user:pass@smtp.example.com:465

# Option C — SMTP host + user/pass
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password

# --- Security / CORS (set before production) ---

# Comma-separated site origins allowed to call the API.
# Leave unset for local `pnpm dev:all` (development allows any Origin, with a warning).
# In production, empty CORS_ORIGINS rejects browser Origins — set this explicitly:
# CORS_ORIGINS=https://unitedbba.com,https://www.unitedbba.com

# Set to 1 (or true) when the API is behind a reverse proxy / load balancer so
# rate limiting uses the real client IP from X-Forwarded-For.
# TRUST_PROXY=1

# Lead-form rate limit (per IP). Defaults: 30 submissions / 15 minutes.
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=30

# Minimum milliseconds between form open and submit (timing spam filter). Default 2000.
# MIN_FORM_MS=2000

# Optional CAPTCHA (Cloudflare Turnstile). Leave unset to keep the form CAPTCHA-free.
# When set, the API expects a `captchaToken` field on POST /api/leads.
# CAPTCHA_SECRET=
# TURNSTILE_SECRET_KEY=
# CAPTCHA_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# If none of the mail options above are set, the API logs emails to the console
# (useful for local testing) and still returns success to the form.
